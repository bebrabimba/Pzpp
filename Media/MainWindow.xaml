<Window x:Class="Media.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:local="clr-namespace:Media"
        mc:Ignorable="d"
        Title="Muzyczka" Height="640" Width="1080"
        MinHeight="560" MinWidth="920"
        Icon="pack://application:,,,/App.ico"
        WindowStyle="None"
        AllowsTransparency="True"
        Background="Transparent">

    <Window.Resources>
        <SolidColorBrush x:Key="Bg" Color="#151920"/>
        <SolidColorBrush x:Key="Panel" Color="#1B2029"/>
        <SolidColorBrush x:Key="Panel2" Color="#202632"/>
        <SolidColorBrush x:Key="TextMain" Color="#F2F4F8"/>
        <SolidColorBrush x:Key="TextMuted" Color="#AAB2C0"/>
        <SolidColorBrush x:Key="Line" Color="#2A3140"/>
        <SolidColorBrush x:Key="Accent" Color="#1ED760"/>

        <Style TargetType="Button">
            <Setter Property="Foreground" Value="White"/>
            <Setter Property="Background" Value="#252B36"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="Padding" Value="16,9"/>
            <Setter Property="FontFamily" Value="Segoe UI"/>
            <Setter Property="FontWeight" Value="SemiBold"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border Background="{TemplateBinding Background}" CornerRadius="18" Padding="{TemplateBinding Padding}">
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                        </Border>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <Style x:Key="NavButton" TargetType="Button" BasedOn="{StaticResource {x:Type Button}}">
            <Setter Property="HorizontalContentAlignment" Value="Left"/>
            <Setter Property="Background" Value="Transparent"/>
            <Setter Property="Padding" Value="14,10"/>
            <Setter Property="Margin" Value="12,2"/>
        </Style>

        <Style x:Key="IconImage" TargetType="Image">
            <Setter Property="Width" Value="32"/>
            <Setter Property="Height" Value="32"/>
            <Setter Property="Stretch" Value="Uniform"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="Margin" Value="8"/>
        </Style>
    </Window.Resources>

    <Border CornerRadius="16" Background="{StaticResource Bg}" BorderBrush="#303848" BorderThickness="1" MouseMove="move">
        <Grid>
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="220"/>
                <ColumnDefinition Width="*"/>
                <ColumnDefinition Width="300"/>
            </Grid.ColumnDefinitions>
            <Grid.RowDefinitions>
                <RowDefinition Height="70"/>
                <RowDefinition Height="*"/>
            </Grid.RowDefinitions>

            <!-- Pasek boczny -->
            <Border Grid.RowSpan="2" Grid.Column="0" Background="#11161D" CornerRadius="16,0,0,16" BorderBrush="{StaticResource Line}" BorderThickness="0,0,1,0">
                <StackPanel>
                    <StackPanel Orientation="Horizontal" Margin="24,28,18,22" VerticalAlignment="Center">
                        <TextBlock Text="♪" FontSize="32" Foreground="White" FontWeight="Bold" Margin="0,0,12,0"/>
                        <TextBlock Text="Muzyczka" FontSize="22" Foreground="White" FontWeight="Bold" VerticalAlignment="Center"/>
                    </StackPanel>

                    <Button Style="{StaticResource NavButton}" Background="#252B36" Content="⌂   Home"/>
                    <Button Style="{StaticResource NavButton}" Content="⌕   Search"/>
                    <Button Style="{StaticResource NavButton}" Content="▥   Library"/>
                    <Button Style="{StaticResource NavButton}" Content="♥   Favorites"/>
                    <Button Style="{StaticResource NavButton}" Content="♫   Playlists"/>

                    <Border Height="1" Background="{StaticResource Line}" Margin="18,14"/>
                    <TextBlock Text="Twoje playlisty" Foreground="White" FontWeight="SemiBold" Margin="24,4,0,14"/>
                    <TextBlock Text="Chill Mix" Foreground="{StaticResource TextMuted}" Margin="24,0,0,13"/>
                    <TextBlock Text="Top Hits" Foreground="{StaticResource TextMuted}" Margin="24,0,0,13"/>
                    <TextBlock Text="Workout" Foreground="{StaticResource TextMuted}" Margin="24,0,0,13"/>
                    <TextBlock Text="Focus" Foreground="{StaticResource TextMuted}" Margin="24,0,0,13"/>
                    <TextBlock Text="Polski Rap" Foreground="{StaticResource TextMuted}" Margin="24,0,0,13"/>
                </StackPanel>
            </Border>

            <!-- Góra: wyszukiwarka + okno -->
            <Grid Grid.Column="1" Grid.Row="0" Grid.ColumnSpan="2" Background="#151920" MouseMove="move">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="Auto"/>
                </Grid.ColumnDefinitions>

                <Border Height="38" Width="520" HorizontalAlignment="Left" Margin="24,16,0,16" Background="#202632" CornerRadius="8">
                    <Grid>
                        <TextBlock Text="⌕" Foreground="{StaticResource TextMuted}" FontSize="22" VerticalAlignment="Center" Margin="14,0,0,0"/>
                        <TextBox x:Name="SearchBox" Text="Szukaj..." TextChanged="SearchBox_TextChanged"
                                 Background="Transparent" BorderThickness="0" Foreground="{StaticResource TextMuted}"
                                 FontSize="14" VerticalContentAlignment="Center" Margin="48,0,12,0"/>
                    </Grid>
                </Border>

                <StackPanel Grid.Column="1" Orientation="Horizontal" HorizontalAlignment="Right" VerticalAlignment="Center" Margin="0,0,12,0">
                    <Image x:Name="button_minimize" Source="/images/minimize.png" Style="{StaticResource IconImage}" MouseLeftButtonDown="button_minimize_MouseLeftButtonDown"/>
                    <Image x:Name="button_close" Source="/images/close.png" Style="{StaticResource IconImage}" MouseLeftButtonDown="button_close_MouseLeftButtonDown"/>
                </StackPanel>
            </Grid>

            <!-- Lista muzyki -->
            <Grid Grid.Column="1" Grid.Row="1" Margin="24,18,20,20">
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="*"/>
                </Grid.RowDefinitions>

                <TextBlock Text="Kategorie" Foreground="White" FontSize="20" FontWeight="Bold" Margin="0,0,0,14"/>
                <StackPanel Grid.Row="1" Orientation="Horizontal" Margin="0,0,0,18">
                    <Button Content="Wszystkie" Background="{StaticResource Accent}" Click="Category_Click"/>
                    <Button Content="Pop" Margin="10,0,0,0" Click="Category_Click"/>
                    <Button Content="Rock" Margin="10,0,0,0" Click="Category_Click"/>
                    <Button Content="Hip-Hop" Margin="10,0,0,0" Click="Category_Click"/>
                    <Button Content="Jazz" Margin="10,0,0,0" Click="Category_Click"/>
                    <Button Content="Electronic" Margin="10,0,0,0" Click="Category_Click"/>
                </StackPanel>

                <Border Grid.Row="2" Background="#171C24" CornerRadius="12" BorderBrush="{StaticResource Line}" BorderThickness="1">
                    <Grid Margin="14">
                        <Grid.RowDefinitions>
                            <RowDefinition Height="38"/>
                            <RowDefinition Height="*"/>
                        </Grid.RowDefinitions>
                        <Grid Grid.Row="0">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="2*"/>
                                <ColumnDefinition Width="1.4*"/>
                                <ColumnDefinition Width="1.4*"/>
                                <ColumnDefinition Width="80"/>
                            </Grid.ColumnDefinitions>
                            <TextBlock Text="Tytuł" Foreground="{StaticResource TextMuted}" FontWeight="SemiBold" VerticalAlignment="Center"/>
                            <TextBlock Grid.Column="1" Text="Artysta" Foreground="{StaticResource TextMuted}" FontWeight="SemiBold" VerticalAlignment="Center"/>
                            <TextBlock Grid.Column="2" Text="Album" Foreground="{StaticResource TextMuted}" FontWeight="SemiBold" VerticalAlignment="Center"/>
                            <TextBlock Grid.Column="3" Text="Czas" Foreground="{StaticResource TextMuted}" FontWeight="SemiBold" VerticalAlignment="Center"/>
                        </Grid>

                        <ListBox x:Name="listBox1" Grid.Row="1"
                                 SelectionChanged="list" DragEnter="DragEnter" Drop="DragDrop" AllowDrop="True"
                                 Background="Transparent" BorderThickness="0" Foreground="White"
                                 Cursor="Hand" FontFamily="Segoe UI" FontSize="14">
                            <ListBox.ItemContainerStyle>
                                <Style TargetType="ListBoxItem">
                                    <Setter Property="Padding" Value="10,11"/>
                                    <Setter Property="Margin" Value="0,1"/>
                                    <Setter Property="Foreground" Value="White"/>
                                    <Setter Property="Template">
                                        <Setter.Value>
                                            <ControlTemplate TargetType="ListBoxItem">
                                                <Border x:Name="Bd" Background="Transparent" CornerRadius="8" Padding="{TemplateBinding Padding}">
                                                    <ContentPresenter/>
                                                </Border>
                                                <ControlTemplate.Triggers>
                                                    <Trigger Property="IsSelected" Value="True">
                                                        <Setter TargetName="Bd" Property="Background" Value="#283140"/>
                                                    </Trigger>
                                                    <Trigger Property="IsMouseOver" Value="True">
                                                        <Setter TargetName="Bd" Property="Background" Value="#202632"/>
                                                    </Trigger>
                                                </ControlTemplate.Triggers>
                                            </ControlTemplate>
                                        </Setter.Value>
                                    </Setter>
                                </Style>
                            </ListBox.ItemContainerStyle>
                        </ListBox>
                    </Grid>
                </Border>
            </Grid>

            <!-- Prawa część: odtwarzacz -->
            <Border Grid.Column="2" Grid.Row="1" Margin="0,18,24,20" Background="#11161D" CornerRadius="12" BorderBrush="{StaticResource Line}" BorderThickness="1">
                <Grid Margin="20">
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="190"/>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="*"/>
                        <RowDefinition Height="Auto"/>
                    </Grid.RowDefinitions>

                    <TextBlock Text="Teraz wybrane" Foreground="White" FontSize="20" FontWeight="Bold" Margin="0,0,0,14"/>

                    <Border Grid.Row="1" Background="#202632" CornerRadius="8" BorderBrush="#333B4C" BorderThickness="1">
                        <Grid>
                            <TextBlock Text="♪" Foreground="#586170" FontSize="96" HorizontalAlignment="Center" VerticalAlignment="Center"/>
                            <WindowsFormsHost Name="winFormsHost" Width="0" Height="0" Visibility="Hidden"/>
                        </Grid>
                    </Border>

                    <TextBlock x:Name="NowTitle" Grid.Row="2" Text="Wybierz utwór" Foreground="White" FontSize="20" FontWeight="Bold" Margin="0,18,0,2" TextWrapping="Wrap"/>
                    <TextBlock x:Name="NowArtist" Grid.Row="3" Text="Artysta" Foreground="{StaticResource TextMuted}" FontSize="14"/>

                    <Border Grid.Row="4" Height="1" Background="{StaticResource Line}" Margin="0,18"/>

                    <StackPanel Grid.Row="5">
                        <TextBlock Text="Informacje" Foreground="White" FontSize="16" FontWeight="Bold" Margin="0,0,0,14"/>
                        <TextBlock x:Name="InfoAlbum" Text="Album: -" Foreground="{StaticResource TextMuted}" Margin="0,0,0,9"/>
                        <TextBlock x:Name="InfoCategory" Text="Kategoria: -" Foreground="{StaticResource TextMuted}" Margin="0,0,0,9"/>
                        <TextBlock x:Name="InfoTime" Text="Czas: -" Foreground="{StaticResource TextMuted}"/>
                    </StackPanel>

                    <StackPanel Grid.Row="6" Margin="0,18,0,0">
                        <ProgressBar x:Name="ProgressBar" Height="7" Minimum="0" Maximum="100" Value="0"
                                     Background="#05070A" BorderBrush="{x:Null}" Cursor="Hand"
                                     MouseLeftButtonDown="ProgressBar_MouseLeftButtonDown"/>
                        <Grid Margin="0,6,0,8">
                            <TextBlock x:Name="time" Text="00:00" Foreground="{StaticResource TextMuted}" HorizontalAlignment="Left"/>
                            <TextBlock x:Name="alltime" Text="00:00" Foreground="{StaticResource TextMuted}" HorizontalAlignment="Right"/>
                        </Grid>

                        <DockPanel LastChildFill="False" HorizontalAlignment="Center" Margin="0,4,0,12">
                            <Image x:Name="previous" Source="/images/last.png" Style="{StaticResource IconImage}" Width="42" Height="42" MouseDown="previousClick"/>
                            <Image x:Name="stop" Source="/images/stop.png" Style="{StaticResource IconImage}" Width="42" Height="42" MouseDown="stopСlick"/>
                            <Image x:Name="pause" Source="/images/pause.png" Style="{StaticResource IconImage}" Width="42" Height="42" MouseDown="pauseСlick"/>
                            <Image x:Name="play" Source="/images/play.png" Style="{StaticResource IconImage}" Width="52" Height="52" MouseDown="playСlick"/>
                            <Image x:Name="next" Source="/images/next.png" Style="{StaticResource IconImage}" Width="42" Height="42" MouseDown="nextClick"/>
                        </DockPanel>

                        <Grid>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="Auto"/>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="48"/>
                                <ColumnDefinition Width="Auto"/>
                            </Grid.ColumnDefinitions>
                            <Image x:Name="volume" Source="/images/volume.png" Width="30" Height="30" VerticalAlignment="Center" Margin="0,0,8,0"/>
                            <Slider x:Name="trackBar" Grid.Column="1" Minimum="0" Maximum="100" Value="50" TickFrequency="1" IsSnapToTickEnabled="True" VerticalAlignment="Center" MouseMove="volumeBarScroll"/>
                            <Label x:Name="value" Grid.Column="2" Content="50" Foreground="White" FontWeight="Bold" HorizontalContentAlignment="Center" VerticalContentAlignment="Center"/>
                            <Image x:Name="folder" Grid.Column="3" Source="/images/folder.png" Width="34" Height="34" Cursor="Hand" MouseDown="open"/>
                        </Grid>
                    </StackPanel>
                </Grid>
            </Border>
        </Grid>
    </Border>
</Window>
